# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solobackend

# Kinde Auth (public — used by the browser SDK and for JWT verification)
NEXT_PUBLIC_KINDE_ISSUER_URL=https://your-app.kinde.com
NEXT_PUBLIC_KINDE_CLIENT_ID=your_kinde_client_id

# Stripe (server-only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: platform fee when paying bundle creators via Connect (default 10 = 10%)
# STRIPE_APPLICATION_FEE_PERCENT=10
# Restocking fee on refunds: customer pays this (platform keeps it to cover Stripe's non-refunded fee). Default 2.9% + 30¢.
# STRIPE_RESTOCKING_FEE_PERCENT=2.9
# STRIPE_RESTOCKING_FEE_FIXED_CENTS=30
# Cap: restocking fee cannot exceed this % of the charge (customer gets at least (100 - this)% back). Default 50.
# STRIPE_RESTOCKING_FEE_MAX_PERCENT=50

# Cloudflare R2 (server-only)
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY=your_access_key_id
CLOUDFLARE_R2_SECRET_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET=music-bundles
